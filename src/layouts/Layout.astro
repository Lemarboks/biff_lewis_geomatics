---
import TopBar from '../components/TopBar.astro';
import Nav    from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords?: string;
}
const { title, description, keywords } = Astro.props;
const fontStylesheetUrl = 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@600;700;800&display=swap';
const siteUrl = Astro.site ?? new URL('https://www.blgeomatics.co.za');
const cleanPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonicalUrl = new URL(cleanPath, siteUrl).toString();
const businessId = new URL('/#localbusiness', siteUrl).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': businessId,
  name: 'Biff Lewis Geomatics',
  url: new URL('/', siteUrl).toString(),
  telephone: '+27 21 442 3480',
  email: 'info@blgeomatics.co.za',
  legalName: 'Biff Lewis Geomatics Inc.',
  taxID: '4900204153',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'A11 Waverley Court, 7 Kotzee Road',
    addressLocality: 'Observatory',
    postalCode: '7925',
    addressRegion: 'Western Cape',
    addressCountry: 'ZA',
  },
  areaServed: [
    'Cape Town',
    'Western Cape',
    'Southern Suburbs',
    'Northern Suburbs',
    'Atlantic Seaboard',
    'Cape Peninsula',
    'Stellenbosch',
    'Somerset West',
    'Paarl',
    'Hermanus',
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '08:00',
      closes: '17:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Friday',
      opens: '08:00',
      closes: '16:00',
    },
  ],
  priceRange: '$$',
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Biff Lewis Geomatics" />
  <meta property="og:locale" content="en_ZA" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href={fontStylesheetUrl} />
  <link rel="stylesheet" href={fontStylesheetUrl} media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href={fontStylesheetUrl} /></noscript>
</head>
<body>
  <div id="scroll-progress" aria-hidden="true"></div>
  <TopBar />
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>

<script>
  // ── Scroll progress bar ──────────────────────────────────
  const progressBar = document.getElementById('scroll-progress') as HTMLElement | null;
  const updateProgress = () => {
    if (!progressBar) return;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.transform = `scaleX(${max > 0 ? window.scrollY / max : 0})`;
  };
  window.addEventListener('scroll', updateProgress, { passive: true });

  // ── Navbar scroll class ──────────────────────────────────
  const navbar = document.getElementById('navbar') as HTMLElement | null;
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 55);
  }, { passive: true });

  // ── Scroll reveal ────────────────────────────────────────
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          revealObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });

    const selectors = [
      '.section-title', '.section-sub', '.label',
      '.red-bar', '.card', '.testi-card',
      '.about-point', '.type-item', '.stat-cell',
      '.footer-col', '.footer-brand-logo',
    ].join(',');

    // rAF so initial paint happens before classes are added
    requestAnimationFrame(() => {
      document.querySelectorAll(selectors).forEach(el => {
        el.classList.add('reveal');
        revealObs.observe(el);
      });
      document.querySelectorAll(
        '.services-grid, .testi-grid, .type-strip, .stats-bar .container'
      ).forEach(el => el.classList.add('stagger'));
    });

    // Separate bar-grow observer (no translateY conflict)
    const barObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          barObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.6 });
    document.querySelectorAll('.red-bar').forEach(el => barObs.observe(el));
  }

  // ── Counter animation ────────────────────────────────────
  function runCounter(el: Element) {
    const text = el.textContent?.trim() ?? '';
    const num = parseFloat(text);
    if (isNaN(num)) return;
    const suffix = text.replace(/[\d.]/g, '');
    const dur = 1800;
    const t0 = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - t0) / dur, 1);
      const v = num * (1 - Math.pow(1 - p, 3));
      el.textContent = Math.round(v) + suffix;
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  const countObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { runCounter(e.target); countObs.unobserve(e.target); }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.stat-num, .t-num').forEach(el => countObs.observe(el));

  // ── Button ripple ────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.btn').forEach(btn => {
    btn.addEventListener('click', ev => {
      const e = ev as MouseEvent;
      const rect = btn.getBoundingClientRect();
      const r = document.createElement('span');
      r.className = 'btn-ripple';
      const size = Math.max(rect.width, rect.height);
      Object.assign(r.style, {
        width: size + 'px', height: size + 'px',
        left: (e.clientX - rect.left - size / 2) + 'px',
        top:  (e.clientY - rect.top  - size / 2) + 'px',
      });
      btn.appendChild(r);
      r.addEventListener('animationend', () => r.remove());
    });
  });

  // ── Hero parallax ────────────────────────────────────────
  const heroPhoto = document.querySelector<HTMLElement>('.hero-photo');
  if (heroPhoto) {
    window.addEventListener('scroll', () => {
      const s = window.scrollY;
      if (s < window.innerHeight * 1.5)
        heroPhoto.style.transform = `translateY(${s * 0.28}px)`;
    }, { passive: true });
  }

  // ── Card 3-D tilt (pointer devices only) ─────────────────
  if (!reduced && window.matchMedia('(hover: hover) and (min-width: 769px)').matches) {
    document.querySelectorAll<HTMLElement>('.card').forEach(card => {
      card.addEventListener('mousemove', ev => {
        const r = card.getBoundingClientRect();
        const x = (ev.clientX - r.left) / r.width  - 0.5;
        const y = (ev.clientY - r.top)  / r.height - 0.5;
        card.style.transform =
          `perspective(700px) translateY(-4px) rotateX(${-y * 5}deg) rotateY(${x * 5}deg)`;
        card.style.transition = 'box-shadow .12s, border-color .12s';
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
        card.style.transition = 'transform .35s ease, box-shadow .35s ease, border-color .35s ease';
      });
    });
  }
</script>
</html>
