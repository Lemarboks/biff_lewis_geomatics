---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { url } from '../utils/url';
import heroSubSrc from '../assets/gallery/hero-sub.jpg';
---

<Layout
  title="Contact Us | Biff Lewis Geomatics – Land Surveyors Cape Town"
  description="Contact Biff Lewis Geomatics for a land survey quote. Call 021 442 3480, WhatsApp +27 78 667 8552, or fill in our online quote form. Serving Cape Town and the Western Cape."
>

  <!-- PAGE HERO -->
  <div class="page-hero">
    <img class="page-hero-photo" src={heroSubSrc.src} alt="" aria-hidden="true" loading="eager" decoding="async" />
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={url('/')}>Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span aria-current="page">Contact Us</span>
      </nav>
      <h1>Contact Biff Lewis Geomatics</h1>
      <p>Get in touch for a survey quote, professional advice, or to discuss your project. We respond within 1 business day.</p>
    </div>
  </div>
  <div class="hero-accent-bar"></div>

  <!-- CONTACT SECTION -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="contact-layout">

        <!-- LEFT: CONTACT INFO -->
        <div class="contact-info-block">
          <span class="label">Get in Touch</span>
          <h2 id="contact-heading">We'd Love to Hear About Your Project</h2>
          <p>
            Whether you need a straightforward boundary survey or a large-scale infrastructure
            mapping project, our team is ready to listen, advise, and deliver. Use any of the
            channels below — or fill in the quote form.
          </p>

          <address class="contact-details">
            <div class="cd-row">
              <div class="cd-icon-wrap" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.4 1.15 2 2 0 012 .5h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <div class="cd-lbl">Office Phone</div>
                <div class="cd-val"><a href="tel:+27214423480">021 442 3480</a></div>
              </div>
            </div>

            <div class="cd-row">
              <div class="cd-icon-wrap" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
              </div>
              <div>
                <div class="cd-lbl">Mobile / WhatsApp</div>
                <div class="cd-val"><a href="tel:+27786678552">+27 78 667 8552</a></div>
              </div>
            </div>

            <div class="cd-row">
              <div class="cd-icon-wrap" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <div class="cd-lbl">Email</div>
                <div class="cd-val"><a href="mailto:info@blgeomatics.co.za">info@blgeomatics.co.za</a></div>
              </div>
            </div>

            <div class="cd-row">
              <div class="cd-icon-wrap" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="cd-lbl">Physical Address</div>
                <div class="cd-val">
                  A11 Waverley Court<br />
                  7 Kotzee Road<br />
                  Observatory 7925, Cape Town
                </div>
              </div>
            </div>

            <div class="cd-row">
              <div class="cd-icon-wrap" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </div>
              <div>
                <div class="cd-lbl">Social Media</div>
                <div class="cd-val"><a href="https://www.facebook.com/bifflewisgeomatics" target="_blank" rel="noopener">Facebook</a> &nbsp;·&nbsp; <a href="https://www.instagram.com/bifflewisgeomatics" target="_blank" rel="noopener">@bifflewisgeomatics</a></div>
              </div>
            </div>
          </address>

          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/27786678552?text=Hi%2C%20I%27d%20like%20to%20request%20a%20survey%20quote%20from%20Biff%20Lewis%20Geomatics."
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-btn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat on WhatsApp
          </a>

          <!-- Map placeholder -->
          <div class="map-placeholder" role="region" aria-label="Office location">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="36" height="36">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <strong>A11 Waverley Court, 7 Kotzee Road</strong>
            <span>Observatory 7925, Cape Town</span>
            <a
              href="https://maps.google.com/?q=A11+Waverley+Court,+7+Kotzee+Road,+Observatory,+Cape+Town"
              target="_blank"
              rel="noopener noreferrer"
              class="map-link"
            >
              Open in Google Maps &rarr;
            </a>
          </div>

          <!-- Office hours -->
          <div class="hours-strip" style="margin-top:24px;" aria-label="Office hours">
            <div class="hours-cell">
              <h5>Mon – Thu</h5>
              <p>08:00 – 17:00</p>
            </div>
            <div class="hours-cell">
              <h5>Friday</h5>
              <p>08:00 – 16:00</p>
            </div>
            <div class="hours-cell closed">
              <h5>Sat – Sun</h5>
              <p>Closed</p>
            </div>
          </div>
        </div>

        <!-- RIGHT: QUOTE FORM -->
        <div class="quote-form-box">
          <div class="form-title">Request a Survey Quote</div>
          <div class="form-sub">Fill in the form below and we'll respond with a tailored proposal within 1 business day.</div>

          <form id="quoteForm" novalidate aria-label="Survey quote request form">

            <div class="form-row">
              <div class="form-group">
                <label for="fname">Full Name <span aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
                <input type="text" id="fname" name="fname" placeholder="e.g. Johan Smith" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="company">Company / Organisation</label>
                <input type="text" id="company" name="company" placeholder="e.g. Smith Developments" autocomplete="organization" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">Phone Number <span aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
                <input type="tel" id="phone" name="phone" placeholder="+27 82 000 0000" required autocomplete="tel" />
              </div>
              <div class="form-group">
                <label for="email">Email Address <span aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
              </div>
            </div>

            <div class="form-group">
              <label for="property_address">Property / Site Address or Location</label>
              <input type="text" id="property_address" name="property_address" placeholder="e.g. 15 Main Road, Claremont, Cape Town" autocomplete="street-address" />
            </div>

            <div class="form-group">
              <label for="survey_type">Type of Survey Required <span aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
              <select id="survey_type" name="survey_type" required>
                <option value="" disabled selected>Select survey type…</option>
                <option>Boundary / Property Survey</option>
                <option>Building Depiction</option>
                <option>Topographic Survey</option>
                <option>Construction Setting Out</option>
                <option>As-Built Survey</option>
                <option>CAD Drawing / 3D Model</option>
                <option>Land Subdivision</option>
                <option>Land Development Survey</option>
                <option>Asset / Infrastructure Mapping</option>
                <option>I'm not sure — please advise</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Project Description / Additional Details</label>
              <textarea id="message" name="message" placeholder="Describe your project, property size, specific requirements, or any questions you have…"></textarea>
            </div>

            <div class="form-group">
              <label for="how_heard">How did you hear about us?</label>
              <select id="how_heard" name="how_heard">
                <option value="" disabled selected>Please select…</option>
                <option>Google search</option>
                <option>Referred by a colleague or friend</option>
                <option>Previous client</option>
                <option>Attorney / Estate agent referral</option>
                <option>Architect / Engineer referral</option>
                <option>Other</option>
              </select>
            </div>

            <div class="quote-hp" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <!-- Inline validation error summary -->
            <div id="formErrors" class="form-errors" role="alert" aria-live="polite" hidden></div>

            <button type="submit" class="form-submit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              Send My Quote Request
            </button>
            <p class="form-note">We respond within 1 business day. Your details are kept strictly confidential and will never be shared.</p>
          </form>

          <div class="form-success" id="formSuccess" role="status" aria-live="polite">
            ✓ Thank you, your quote request has been received! We'll be in touch within 1 business day.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section section--alt" aria-labelledby="area-heading">
    <div class="container">
      <span class="label">Where We Work</span>
      <h2 class="section-title" id="area-heading">Service Area — Western Cape</h2>
      <p class="section-sub">
        We are based in Observatory, Cape Town, and serve clients across the Western Cape.
        Contact us if your project is in a region not listed — we may still be able to assist.
      </p>
      <ul class="area-grid" aria-label="Areas we serve">
        {[
          'Cape Town CBD', 'Southern Suburbs', 'Northern Suburbs', 'Atlantic Seaboard',
          'False Bay', 'Cape Peninsula', 'Stellenbosch', 'Somerset West',
          'Paarl', 'Franschhoek', 'Hermanus', 'Bellville',
        ].map(area => <li class="area-tag">{area}</li>)}
      </ul>
    </div>
  </section>

  <!-- WHAT HAPPENS NEXT -->
  <section class="section" aria-labelledby="next-heading">
    <div class="container">
      <span class="label">What to Expect</span>
      <h2 class="section-title" id="next-heading">What Happens After You Contact Us</h2>
      <ol class="next-steps" aria-label="Our response process">
        <li class="next-step">
          <div class="next-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8B1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.4 1.15 2 2 0 012 .5h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h4>1. We Call You Back</h4>
          <p>We'll follow up within 1 business day to understand your exact needs.</p>
        </li>
        <li class="next-step">
          <div class="next-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8B1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h4>2. Written Proposal</h4>
          <p>We send a clear written fee proposal with scope, timeline, and deliverables.</p>
        </li>
        <li class="next-step">
          <div class="next-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8B1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/></svg>
          </div>
          <h4>3. Field Survey</h4>
          <p>Our team visits your site and collects all required data professionally.</p>
        </li>
        <li class="next-step">
          <div class="next-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#8B1A1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          </div>
          <h4>4. Certified Delivery</h4>
          <p>You receive a professionally certified survey deliverable, ready to use.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    heading="Not Sure What Survey You Need?"
    body="Give us a call or send a WhatsApp — we'll advise you at no charge on the right type of survey for your situation."
  >
    <div slot="buttons">
      <a href="tel:+27214423480" class="btn btn--white">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.4 1.15 2 2 0 012 .5h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        Call 021 442 3480
      </a>
      <a
        href="https://wa.me/27786678552?text=Hi%2C%20I%27d%20like%20some%20advice%20on%20a%20land%20survey."
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--outline-white"
      >
        WhatsApp Us
      </a>
    </div>
  </CtaBanner>

</Layout>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 56px;
    align-items: start;
  }

  .contact-info-block h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: 22px; font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 14px;
  }
  .contact-info-block > p {
    font-size: 15px; color: var(--mid); line-height: 1.75; margin-bottom: 32px;
  }

  address { font-style: normal; }
  .contact-details { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
  .cd-row { display: flex; gap: 14px; align-items: flex-start; }
  .cd-icon-wrap {
    width: 42px; height: 42px; flex-shrink: 0;
    background: var(--red-light);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .cd-icon-wrap svg { width: 18px; height: 18px; color: var(--red); }
  .cd-lbl  { font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--grey); }
  .cd-val  { font-size: 15px; font-weight: 500; color: var(--charcoal); line-height: 1.5; }
  .cd-val a { color: var(--charcoal); transition: color .15s; }
  .cd-val a:hover { color: var(--red); }

  .whatsapp-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: #25d366;
    color: var(--white);
    padding: 13px 22px;
    border-radius: var(--radius);
    font-size: 15px; font-weight: 700;
    transition: background .2s;
    margin-bottom: 32px;
  }
  .whatsapp-btn:hover { background: #1fb558; transform: translateY(-1px); }

  .map-placeholder {
    background: var(--grey-bg);
    border: 1px solid var(--grey-light);
    border-radius: 8px;
    height: 220px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; gap: 8px; color: var(--grey);
  }
  .map-placeholder svg { color: var(--red); opacity: .5; }
  .map-placeholder strong { display: block; font-size: 14px; font-weight: 700; color: var(--charcoal); }
  .map-placeholder span  { font-size: 13px; }
  .map-link {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 13px; font-weight: 600; color: var(--red);
    margin-top: 6px;
  }

  .quote-form-box {
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-top: 4px solid var(--red);
    border-radius: 8px;
    padding: 40px;
    box-shadow: var(--shadow);
  }
  .quote-form-box .form-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 20px; font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 6px;
  }
  .quote-form-box .form-sub { font-size: 13.5px; color: var(--grey); margin-bottom: 28px; }

  .form-errors {
    background: #fdf3f3;
    border: 1px solid var(--red-border);
    border-radius: var(--radius);
    padding: 12px 16px;
    color: var(--red);
    font-size: 14px;
    margin-bottom: 16px;
  }

  .quote-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .hours-strip {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--grey-light);
    border: 1px solid var(--grey-light);
    border-radius: 8px; overflow: hidden;
    margin-top: 48px;
  }
  .hours-cell { background: var(--white); padding: 20px 18px; text-align: center; }
  .hours-cell h5  { font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--grey); margin-bottom: 4px; }
  .hours-cell p   { font-size: 14px; font-weight: 600; color: var(--charcoal); }
  .hours-cell.closed p { color: var(--red); }

  .area-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 10px; margin-top: 32px; list-style: none; padding: 0;
  }
  .area-tag {
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-radius: 6px;
    padding: 11px 14px; text-align: center;
    font-size: 13px; font-weight: 600; color: var(--charcoal);
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  .area-tag::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--red); border-radius: 50%; flex-shrink: 0;
  }

  .next-steps {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px; margin-top: 36px; list-style: none; padding: 0;
  }
  .next-step { text-align: center; padding: 24px 16px; }
  .next-icon {
    width: 52px; height: 52px;
    background: var(--red-light); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
  }
  .next-step h4 { font-size: 15px; font-weight: 700; color: var(--charcoal); margin-bottom: 8px; }
  .next-step p  { font-size: 13.5px; color: var(--mid); }

  @media (max-width: 1024px) {
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
    .area-grid       { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) {
    .hours-strip { grid-template-columns: 1fr; }
    .area-grid   { grid-template-columns: 1fr 1fr; }
    .quote-form-box { padding: 24px; }
  }
</style>

<script>
  const form        = document.getElementById('quoteForm')   as HTMLFormElement | null;
  const successBox  = document.getElementById('formSuccess') as HTMLElement | null;
  const errorsBox   = document.getElementById('formErrors')  as HTMLElement | null;
  const submitBtn   = form?.querySelector<HTMLButtonElement>('.form-submit') ?? null;
  const defaultHtml  = submitBtn?.innerHTML ?? '';

  function setError(message: string): void {
    if (!errorsBox) return;
    errorsBox.textContent = message;
    errorsBox.removeAttribute('hidden');
    errorsBox.focus?.();
  }

  function clearError(): void {
    errorsBox?.setAttribute('hidden', '');
  }

  function setPending(isPending: boolean): void {
    if (!submitBtn) return;
    submitBtn.disabled = isPending;
    submitBtn.setAttribute('aria-busy', String(isPending));
    submitBtn.innerHTML = isPending ? 'Sending...' : defaultHtml;
  }

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    const fname = (document.getElementById('fname')       as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone')       as HTMLInputElement).value.trim();
    const email = (document.getElementById('email')       as HTMLInputElement).value.trim();
    const type  = (document.getElementById('survey_type') as HTMLSelectElement).value;

    // Client-side validation
    const missing: string[] = [];
    if (!fname) missing.push('Full Name');
    if (!phone) missing.push('Phone Number');
    if (!email) missing.push('Email Address');
    if (!type)  missing.push('Type of Survey Required');

    if (missing.length > 0) {
      setError(`Please fill in the required fields: ${missing.join(', ')}.`);
      return;
    }

    clearError();
    setPending(true);

    try {
      const payload = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/quote', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const result = await res.json().catch(() => ({}));

      if (!res.ok || result.ok === false) {
        const serverErrors = Array.isArray(result.errors) ? ` ${result.errors.join(' ')}` : '';
        setError(`${result.message || 'Your quote request could not be sent.'}${serverErrors}`);
        return;
      }

      if (form)       form.style.display = 'none';
      if (successBox) successBox.style.display = 'block';

      const formBox = document.querySelector('.quote-form-box') as HTMLElement | null;
      if (formBox) {
        window.scrollTo({ top: formBox.offsetTop - 100, behavior: 'smooth' });
      }
    } catch {
      setError('Your quote request could not be sent. Please check your connection and try again.');
    } finally {
      setPending(false);
    }
  });
</script>
