---
import Layout from '../layouts/Layout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { url } from '../utils/url';
import heroSubSrc from '../assets/gallery/hero-sub.jpg';

const services = [
  {
    id: 'boundary',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Property Ownership',
    subtitle: 'Cadastral Survey · Boundary Surveys · Depictions',
    paras: [
      'We establish, confirm, or resolve property boundaries with legal precision. Whether you are buying or selling property, planning construction near a boundary, or resolving a dispute with a neighbour, a professionally certified boundary survey gives you certainty.',
      'Our cadastral survey work includes the preparation of Surveyor General diagrams, general plans, and notarial tie diagrams — all certified and accepted by the Surveyor General\'s office and the Deeds Registry.',
    ],
    details: [
      'Boundary demarcation and pegging',
      'Surveyor General diagrams &amp; general plans',
      'Property ownership verification',
      'Boundary dispute resolution',
      'Notarial tie diagrams',
      'Title deed boundary checks',
    ],
    tags: ['Property Owners', 'Attorneys', 'Estate Agents', 'Developers'],
  },
  {
    id: 'engineering',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>`,
    title: 'Measurement Services',
    subtitle: 'Construction Setting Out · As-Built Surveys · Engineering',
    paras: [
      'Precise on-site measurements are the foundation of every successful construction project. We provide survey support at every stage — from initial setting out and level surveys to progress monitoring and final as-built verification.',
      'Our engineers and construction clients rely on our accuracy and speed to keep projects on schedule. We understand tight timelines and deliver results that your team can act on immediately.',
    ],
    details: [
      'Construction setting out',
      'Level and volume surveys',
      'As-built surveys &amp; verification',
      'Infrastructure surveys',
      'Monitoring surveys',
      'Road and bulk services surveys',
    ],
    tags: ['Builders', 'Architects', 'Engineers', 'Municipalities'],
  },
  {
    id: 'cad',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>`,
    title: 'Depictions &amp; CAD / 3D Modelling',
    subtitle: 'CAD Drawings · Digital Terrain Models · Spatial Mapping',
    paras: [
      'We produce detailed technical drawings, digital terrain models (DTMs), and spatial mapping outputs that architects, engineers, and planners can work from directly. Our CAD and 3D modelling services translate survey data into precise, usable digital deliverables.',
      'Whether you need a topographic map for a planning application, a digital surface model for drainage design, or accurate CAD drawings for a development, we deliver to specification — in formats compatible with standard design software.',
    ],
    details: [
      'Topographic surveys &amp; maps',
      'Digital Terrain Models (DTM)',
      'CAD drawings (AutoCAD compatible)',
      '3D surface &amp; building models',
      'GIS data capture &amp; mapping',
      'Contour plans',
    ],
    tags: ['Architects', 'Engineers', 'Planners', 'Developers'],
  },
  {
    id: 'development',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Land Services',
    subtitle: 'Subdivision · Consolidation · General Plans · Rezoning',
    paras: [
      'Land development projects involve complex interactions between technical survey requirements, municipal planning processes, and legal land registration. We provide the surveying component that underpins every stage — from initial feasibility through to formal registration.',
      'We work closely with town planners, attorneys, and municipalities to ensure that all survey deliverables meet the required specifications for approval and lodgement with the Surveyor General and Deeds Registry.',
    ],
    details: [
      'Subdivision surveys &amp; diagrams',
      'Consolidation surveys',
      'Township establishment surveys',
      'General plans',
      'Servitude surveys',
      'Rezoning support documentation',
    ],
    tags: ['Developers', 'Municipalities', 'Attorneys', 'Planners'],
  },
  {
    id: 'asset',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
    title: 'Asset Management',
    subtitle: 'Infrastructure Mapping · GIS · Spatial Data Capture',
    paras: [
      'Accurate spatial records of infrastructure and built assets are critical for ongoing management, maintenance planning, and compliance. We capture, verify, and structure asset data for municipalities, utility providers, and large property portfolios.',
      'Our deliverables are provided in GIS-compatible formats and can be integrated directly into existing asset management systems — providing a reliable, survey-accurate foundation for infrastructure decision-making.',
    ],
    details: [
      'Infrastructure as-built surveys',
      'Asset register surveys',
      'Underground services mapping',
      'GIS data capture &amp; integration',
      'Facility &amp; property surveys',
      'Spatial database creation',
    ],
    tags: ['Municipalities', 'Utilities', 'Government', 'Large Portfolios'],
  },
];

const faqs = [
  {
    id: 'faq-1',
    q: 'What is the difference between a cadastral survey and a topographic survey?',
    a: 'A <strong>cadastral survey</strong> deals with legal property boundaries — it establishes, confirms, or records who owns what land, and produces documents accepted by the Deeds Registry and Surveyor General. A <strong>topographic survey</strong> records the physical features of the land — contours, buildings, trees, services — and is used as a base for design and planning. Both types are common in our practice, and we\'ll advise which is right for your specific project.',
  },
  {
    id: 'faq-2',
    q: 'Do I need a survey before I can subdivide my property?',
    a: 'Yes. Any formal subdivision of land in South Africa requires a survey by a registered Professional Land Surveyor. The surveyor prepares a subdivision diagram (or general plan) which is lodged with the relevant Surveyor General\'s office, and a notarial deed is subsequently registered at the Deeds Registry. Without this step, the subdivision cannot be formally recognised. Contact us early in your subdivision process — we can advise on timing and requirements.',
  },
  {
    id: 'faq-3',
    q: 'How long does a survey take?',
    a: 'Turnaround time depends on the survey type and project complexity. A simple boundary check or topographic survey of a residential property might be completed in 2–5 working days. Subdivision surveys requiring Surveyor General lodgement can take several weeks to months due to the government approval process — though the field and office work is typically done quickly on our end. We\'ll give you a realistic timeline with every proposal.',
  },
  {
    id: 'faq-4',
    q: 'What is a "depiction" in land surveying?',
    a: 'A depiction is a technical drawing produced by a registered surveyor that shows the relationship between a building (or other structure) and the property boundaries. Depictions are often required by municipalities when applying for building plan approval — they verify that a building complies with the building lines and setback requirements registered against the title deed. We produce depictions for both new builds and existing structures.',
  },
  {
    id: 'faq-5',
    q: 'Can you help with a dispute about a boundary between my property and my neighbour\'s?',
    a: 'Yes, this is one of our most common requests. We locate and re-establish the original survey beacons (pegs) using the registered survey diagram from the Surveyor General\'s records, and produce a certified professional opinion on the position of the boundary. This documentation is often used to resolve disputes without litigation — or as evidence if legal proceedings are necessary. Contact us for a consultation.',
  },
];
---

<Layout
  title="Services | Biff Lewis Geomatics – Land Surveyors Cape Town"
  description="Land surveying services from Biff Lewis Geomatics: boundary surveys, engineering surveys, CAD & 3D modelling, land development, and asset mapping across Cape Town and the Western Cape."
  keywords="boundary survey Cape Town, engineering survey Western Cape, CAD drawing land survey, property subdivision Cape Town, cadastral survey Cape Town, land development survey"
>

  <!-- PAGE HERO -->
  <div class="page-hero">
    <img class="page-hero-photo" src={heroSubSrc.src} alt="" aria-hidden="true" loading="eager" decoding="async" />
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={url('/')}>Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">›</span>
        <span aria-current="page">Services</span>
      </nav>
      <h1>Our Surveying Services</h1>
      <p>From property boundary surveys to full 3D digital models — professional, certified geomatics services across Cape Town and the Western Cape.</p>
    </div>
  </div>
  <div class="hero-accent-bar"></div>

  <!-- SERVICES LIST -->
  <section class="section" aria-labelledby="svc-heading">
    <div class="container">
      <span class="label">What We Offer</span>
      <h2 class="section-title" id="svc-heading">Five Core Service Areas</h2>
      <p class="section-sub">Each service is delivered by SAGC-registered surveyors using calibrated, modern equipment — and certified for legal, planning, and construction use.</p>

      <div class="svc-list">
        {services.map(svc => (
          <article class="svc-item" id={svc.id} aria-labelledby={`${svc.id}-title`}>
            <div class="svc-icon-wrap" aria-hidden="true">
              <Fragment set:html={svc.icon} />
            </div>
            <div class="svc-body">
              <h3 id={`${svc.id}-title`}><Fragment set:html={svc.title} /></h3>
              <div class="svc-subtitle">{svc.subtitle}</div>
              {svc.paras.map(p => <p>{p}</p>)}
              <ul class="svc-details" aria-label="Service details">
                {svc.details.map(d => (
                  <li class="svc-detail">
                    <span class="svc-detail-dot" aria-hidden="true"></span>
                    <Fragment set:html={d} />
                  </li>
                ))}
              </ul>
              <div class="svc-footer">
                <div class="tags" aria-label="Client types">
                  {svc.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
                <a href={url('/contact')} class="btn btn--red" style="padding:10px 20px;font-size:13px;">Request This Service</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section section--alt" aria-labelledby="process-heading">
    <div class="container">
      <span class="label">Our Approach</span>
      <h2 class="section-title" id="process-heading">How Every Project Is Handled</h2>
      <p class="section-sub">From enquiry to certified delivery — a structured, transparent process every time.</p>
      <ol class="process-row" aria-label="Our process">
        <li class="pr-step">
          <div class="pr-num" aria-hidden="true">1</div>
          <h4>Briefing &amp; Proposal</h4>
          <p>We listen to your requirements, define the project scope, and issue a written fee proposal within 1 business day.</p>
        </li>
        <li class="pr-step">
          <div class="pr-num" aria-hidden="true">2</div>
          <h4>Site Visit &amp; Field Survey</h4>
          <p>Our team visits the site with calibrated survey instruments to collect all required measurements and spatial data.</p>
        </li>
        <li class="pr-step">
          <div class="pr-num" aria-hidden="true">3</div>
          <h4>Processing &amp; Drafting</h4>
          <p>Survey data is processed, verified, and formatted — CAD drawings, reports, models, and plans produced to specification.</p>
        </li>
        <li class="pr-step">
          <div class="pr-num" aria-hidden="true">4</div>
          <h4>Certified Delivery</h4>
          <p>Final deliverables are certified, signed, and handed over in the agreed format — ready for legal, planning, or construction use.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <span class="label">Common Questions</span>
      <h2 class="section-title" id="faq-heading">Frequently Asked Questions</h2>
      <p class="section-sub">Not sure which survey you need? Here are answers to common questions from our clients.</p>
      <div class="faq-list">
        {faqs.map(faq => (
          <div class="faq-item">
            <button
              class="faq-q"
              type="button"
              aria-expanded="false"
              aria-controls={faq.id}
            >
              {faq.q}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <div class="faq-a" id={faq.id} role="region" aria-labelledby={faq.id}>
              <Fragment set:html={faq.a} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    heading="Not Sure Which Service You Need?"
    body="Contact us — we'll help you identify the right survey for your project and provide a clear, written proposal."
    btn1={{ text: 'Get a Quote',  href: url('/contact') }}
    btn2={{ text: 'About Us',    href: url('/about') }}
  />

</Layout>

<style>
  .svc-list { display: flex; flex-direction: column; gap: 32px; margin-top: 48px; }
  .svc-item {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 28px;
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-radius: 8px;
    padding: 36px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }
  .svc-item::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 100%; height: 3px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .25s;
  }
  .svc-item:hover { box-shadow: var(--shadow-lg); }
  .svc-item:hover::before { transform: scaleX(1); }

  .svc-icon-wrap {
    width: 72px; height: 72px; flex-shrink: 0;
    background: var(--red-light);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .svc-icon-wrap svg { width: 36px; height: 36px; color: var(--red); }

  .svc-body h3 { font-family: 'Montserrat', sans-serif; font-size: 20px; font-weight: 800; color: var(--charcoal); margin-bottom: 6px; }
  .svc-subtitle { font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 14px; letter-spacing: .03em; }
  .svc-body p  { font-size: 14.5px; color: var(--mid); line-height: 1.75; margin-bottom: 16px; }

  .svc-details { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 24px; margin-bottom: 20px; list-style: none; padding: 0; }
  .svc-detail  { display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--charcoal); }
  .svc-detail-dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; flex-shrink: 0; }

  .svc-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; padding-top: 16px; border-top: 1px solid var(--grey-light); }

  .process-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
    margin-top: 44px; position: relative; list-style: none; padding: 0;
  }
  .process-row::before {
    content: '';
    position: absolute; top: 26px; left: 12%; right: 12%;
    height: 2px; background: var(--grey-light);
  }
  .pr-step { display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; z-index: 1; }
  .pr-num {
    width: 52px; height: 52px;
    background: var(--charcoal); color: #e87070;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 800;
    margin-bottom: 18px;
    border: 4px solid var(--white);
    box-shadow: 0 0 0 2px var(--charcoal);
  }
  .pr-step h4 { font-size: 14px; font-weight: 700; color: var(--charcoal); margin-bottom: 6px; }
  .pr-step p  { font-size: 13px; color: var(--mid); line-height: 1.6; padding: 0 4px; }

  .faq-list { display: flex; flex-direction: column; gap: 14px; margin-top: 40px; }
  .faq-item {
    background: var(--white);
    border: 1px solid var(--grey-light);
    border-radius: 6px;
    overflow: hidden;
  }
  .faq-q {
    width: 100%;
    padding: 18px 22px;
    font-size: 15px; font-weight: 600;
    color: var(--charcoal);
    cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    background: none;
    border: none;
    text-align: left;
    transition: background .15s;
    font-family: inherit;
  }
  .faq-q:hover { background: var(--grey-bg); }
  .faq-q svg { width: 18px; height: 18px; color: var(--red); flex-shrink: 0; transition: transform .2s; }
  .faq-q[aria-expanded="true"] svg { transform: rotate(45deg); }
  .faq-a {
    display: none;
    padding: 0 22px 18px;
    font-size: 14px; color: var(--mid);
    line-height: 1.75;
  }
  .faq-a.open { display: block; }

  @media (max-width: 1024px) {
    .process-row { grid-template-columns: 1fr 1fr; gap: 28px; }
    .process-row::before { display: none; }
  }
  @media (max-width: 768px) {
    .svc-item { grid-template-columns: 1fr; gap: 18px; }
    .svc-icon-wrap { width: 56px; height: 56px; }
    .svc-icon-wrap svg { width: 28px; height: 28px; }
    .svc-details { grid-template-columns: 1fr; }
    .process-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement | null;
      if (answer) answer.classList.toggle('open', !expanded);
    });
  });
</script>
